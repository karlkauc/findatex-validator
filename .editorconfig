root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx,mjs,cjs,css,scss,html}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{xml,fxml}]
indent_size = 4

[*.bat]
end_of_line = crlf
