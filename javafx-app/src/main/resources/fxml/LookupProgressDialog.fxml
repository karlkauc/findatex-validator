<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.findatex.validator.ui.LookupProgressController"
      styleClass="progress-dialog" prefWidth="520" stylesheets="@/css/app.css">

  <!-- Header -->
  <VBox styleClass="progress-dialog-header" spacing="2">
    <Label fx:id="phaseLabel" text="Local validation" styleClass="progress-dialog-title"/>
    <Label fx:id="subtitleLabel" text="Working…" styleClass="progress-dialog-subtitle"/>
  </VBox>

  <!-- Body -->
  <VBox styleClass="progress-dialog-body">

    <!-- Files (folder mode only) -->
    <VBox fx:id="batchCard" styleClass="progress-card" managed="false" visible="false">
      <HBox alignment="CENTER_LEFT">
        <Label text="Files" styleClass="card-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="batchCounter" text="0/0" styleClass="card-counter"/>
      </HBox>
      <ProgressBar fx:id="batchBar" maxWidth="Infinity" progress="0"/>
      <Label fx:id="batchLabel" text="" styleClass="card-detail"/>
    </VBox>

    <!-- GLEIF -->
    <VBox fx:id="gleifCard" styleClass="progress-card">
      <HBox alignment="CENTER_LEFT">
        <Label text="GLEIF lookup" styleClass="card-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="gleifLabel" text="0/0" styleClass="card-counter"/>
      </HBox>
      <ProgressBar fx:id="gleifBar" maxWidth="Infinity" progress="0"/>
    </VBox>

    <!-- OpenFIGI -->
    <VBox fx:id="figiCard" styleClass="progress-card">
      <HBox alignment="CENTER_LEFT">
        <Label text="OpenFIGI lookup" styleClass="card-title"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="figiLabel" text="0/0" styleClass="card-counter"/>
      </HBox>
      <ProgressBar fx:id="figiBar" maxWidth="Infinity" progress="0"/>
    </VBox>

    <Label fx:id="cacheLabel" text="" styleClass="progress-cache-line"/>
  </VBox>

  <!-- Footer -->
  <HBox alignment="CENTER_RIGHT" styleClass="progress-dialog-footer">
    <Button fx:id="cancelButton" text="Cancel" onAction="#onCancel" styleClass="cancel-button"/>
  </HBox>
</VBox>
