<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" styleClass="root-pane">

    <top>
        <VBox spacing="6" styleClass="top-bar">
            <padding><Insets top="14" right="20" bottom="10" left="20"/></padding>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="FinDatEx Validator" styleClass="app-title">
                    <font><Font name="System Bold" size="22"/></font>
                </Label>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="settingsButton" text="⚙ Settings…" onAction="#onSettings"/>
            </HBox>
            <Label text="Load a FinDatEx data template file (Excel or CSV) and check it for completeness, format conformance and cross-field consistency."
                   wrapText="true" styleClass="app-subtitle"/>
        </VBox>
    </top>

    <center>
        <!-- Tabs added programmatically by MainController from TemplateRegistry.all(). -->
        <TabPane fx:id="templateTabs" tabClosingPolicy="UNAVAILABLE"/>
    </center>

</BorderPane>
